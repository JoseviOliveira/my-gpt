<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
 "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>my-gpt</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/YOUR_USER/my-gpt/deploy/launchd-run.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/YOUR_USER/my-gpt</string>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/Users/YOUR_USER/my-gpt/log/launchd.out.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/YOUR_USER/my-gpt/log/launchd.err.log</string>
</dict>
</plist>
