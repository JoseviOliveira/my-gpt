{
  log {
    # Replace with your repo path
    output file /Users/YOUR_USER/my-gpt/log/caddy.log
    format json
  }
}

# Replace with your public domain (or local DNS name).
YOUR_DOMAIN {
  encode zstd gzip

  # Optional: enable after first successful HTTPS issuance
  # header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  reverse_proxy 127.0.0.1:4200 {
    header_up X-Forwarded-Proto {scheme}
    header_up X-Forwarded-For {remote_host}
    header_up Host {host}
  }
}
